# Shared RehabSync Supabase Postgres (pooler string). Same DB as the main platform.
REHABSYNC_DATABASE_URL=postgresql://user:pass@host:6543/postgres

# Main RehabSync API origin — used to verify platform super-admin SSO sessions.
REHABSYNC_API_URL=https://api.rehabsync.app

# 'production' enables secure cookies.
REHABSYNC_NODE_ENV=development

# Public origin of this app.
NEXT_PUBLIC_APP_URL=https://adscentre.rehabsync.app

# ── M1+ (social publishing) ──────────────────────────────────────────────────
# REHABSYNC_ENCRYPTION_KEY=            # AES-256-GCM for oauth tokens at rest
# REHABSYNC_SUPABASE_URL=              # ads-media storage
# REHABSYNC_SUPABASE_SERVICE_KEY=
# CRON_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=                    # YouTube
# GOOGLE_CLIENT_SECRET=

# ── M3 (newsletters) ─────────────────────────────────────────────────────────
# REHABSYNC_SMTP2GO_API_KEY=
# REHABSYNC_SMTP2GO_WEBHOOK_SECRET=
# REHABSYNC_ADS_EMAIL_TOKEN_SECRET=    # HMAC for unsubscribe + double-opt-in confirm links
# REHABSYNC_EMAIL_SENDER=              # e.g. RehabSync <news@rehabsync.app>
# REHABSYNC_COMPANY_ADDRESS=           # shown in the compliance footer
